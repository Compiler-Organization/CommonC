// i32 factorize(i32 n) -> Factorizes the given number and returns the product of its factors.
// isPrime(i32 n) -> Checks if the given number is prime.

i32 factorize(i32 n) {
	i32 result = 1
	for 2..n, i {
		if (n % i) == 0 {
			result *= i
		}
	}
	return result
}

bool isPrime(i32 n) {
	if n <= 1
		return false
	for 2..n, i {
		if (n % i) == 0
			return false
	}
	return true
}